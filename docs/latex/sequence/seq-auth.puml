@startuml seq-auth
hide footbox
' 控制单页：过宽/过高时 PlantUML 会拆成多页 PDF，LaTeX 默认只显示第 1 页
scale max 1300 width
scale max 2000 height
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
title 登录认证（注册 / 登录 / 登出）

actor "客户端" as Client
participant "AuthController" as Ctl
participant "AuthService" as Svc
participant "AuthManager" as AM
participant "UserDetailsService" as UDS
participant "Mapper" as Mapper
participant "PasswordEncoder" as PE
participant "TokenProvider" as JWT
database "MySQL" as DB
database "Redis" as Redis

== 注册 ==

Client -> Ctl : POST /api/auth/register
Ctl -> Svc : register
Svc -> Mapper : selectOne / insert
Mapper -> DB : SELECT / INSERT
Ctl --> Client : 200 / 用户名已存在

== 登录 ==

Client -> Ctl : POST /api/auth/login
Ctl -> Svc : login(userType)
Svc -> AM : authenticate
AM -> UDS : loadUserByUsername
UDS -> Mapper : 查 user 或 admin
Mapper -> DB : SELECT
alt 失败
  Ctl --> Client : 401
else 成功
  Svc -> JWT : generateToken
  Ctl --> Client : 200 + JWT
end

== 登出 ==

Client -> Ctl : POST /api/auth/logout + Bearer
Ctl -> Svc : logout
Svc -> JWT : validate / getExpiration
Svc -> Redis : token 黑名单 (TTL)
Ctl --> Client : 200

@enduml
