<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yanzy.codejudge.mapper.ProblemMapper">
    <select id="getProblemList" resultType="com.yanzy.codejudge.vo.ProblemInfoVO">
        select id as problemId, difficulty, title, created_at as createdAt
        from problem
        order by created_at asc, id asc;
    </select>
</mapper>