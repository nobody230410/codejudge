<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yanzy.codejudge.mapper.TestCaseMapper">

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        insert into code_judge.test_case (problem_id, input, output, input_hash)
        values
            <foreach collection="testCases" item="tc" separator=",">
                (#{tc.problemId}, #{tc.input}, #{tc.output}, #{tc.inputHash})
            </foreach>
    </insert>
</mapper>